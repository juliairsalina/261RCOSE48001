# ── Backend API ────────────────────────────────────────────────────────────
# URL of the main FastAPI backend (career-application-agent-backend)
# Used by the resume upload flow and the edit-resume page
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# URL of the resume preprocessing / parser service (if separate from main API)
# If you run a single FastAPI backend, set this to the same value as above
NEXT_PUBLIC_PREPROCESS_API_URL=http://localhost:8000
