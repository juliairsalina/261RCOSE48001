# ── OpenAI ─────────────────────────────────────────────────────────────────
# Required. Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Main LLM model — used for resume parsing, ATS evaluation, rewrite, cover letter
OPENAI_MODEL=gpt-5

# Embedding model — used to generate resume chunk vectors for RAG
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Supabase ────────────────────────────────────────────────────────────────
# Your Supabase project URL  (Settings → API → Project URL)
SUPABASE_URL=

# Backend-only service role key — NEVER expose to frontend
# (Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=

# Anon / public key — safe to use from frontend (Settings → API → anon public)
SUPABASE_ANON_KEY=

# Storage bucket name for uploaded resumes and exported DOCX files
SUPABASE_BUCKET=resumes

# ── LangSmith tracing (optional but recommended) ────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=career-application-agent

# ── Job Search API ──────────────────────────────────────────────────────────
# Provider name — "adzuna" is the default implementation.
# To swap providers add a new class in job_search_service.py and change this.
JOB_SEARCH_PROVIDER=adzuna

# Adzuna credentials — register at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
MAX_FILE_SIZE_MB=10
