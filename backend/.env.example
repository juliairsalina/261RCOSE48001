# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_BUCKET=resumes

# Job Search
# Options: openai_web (default, uses OpenAI web_search_preview), jsearch (requires JSEARCH_API_KEY), dummy
JOB_SEARCH_PROVIDER=openai_web
JSEARCH_API_KEY=
JSEARCH_COUNTRY=kr
JSEARCH_LANGUAGE=en

# LangSmith optional
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=career-application-agent

# App
APP_ENV=development
